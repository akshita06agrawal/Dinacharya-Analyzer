{
  "name": "dinacharya-analyzer",
  "version": "1.0.0",
  "description": "Vedic Routine Analyzer — Full-stack app with DevOps pipeline (Docker, K8s, CI/CD)",
  "main": "backend/server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint backend/ --ext .js",
    "docker:build": "docker build -t dinacharya-analyzer:latest .",
    "docker:run": "docker run -p 3000:3000 --env-file .env dinacharya-analyzer:latest",
    "docker:push": "docker push your-dockerhub-username/dinacharya-analyzer:latest"
  },
  "keywords": [
    "ayurveda", "vedic", "health", "nodejs", "express", "docker", "kubernetes", "devops"
  ],
  "author": "Kunal",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  }
}
